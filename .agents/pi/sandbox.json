{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": ["github.com", "*.github.com", "raw.githubusercontent.com", "mcp.context7.com"],
    "deniedDomains": []
  },
  "filesystem": {
    "allowRead": [".", "~/.config", "~/.local", "Library", "~/.pi"],
    "allowWrite": [".", "/tmp"],
    "denyRead": ["/Users", "/home"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
