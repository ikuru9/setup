{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hook.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__fixture__scan",
        "hooks": [
          {
            "type": "http",
            "url": "https://example.invalid/hook",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Summarize the completed subagent result",
            "timeout": 10
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "tool": "fixture/ask"
          }
        ]
      }
    ]
  }
}
